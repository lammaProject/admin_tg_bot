# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID канала (например: @my_channel или -1001234567890)
CHANNEL_ID=@your_channel_here

# Время публикации (МСК, формат HH:MM)
POST_TIME=09:00

# Часовой пояс (по умолчанию Europe/Moscow)
TIMEZONE=Europe/Moscow

# Release source: yandex_music, yandex_music_web, or html
RELEASES_SOURCE=yandex_music
RELEASES_TIMEZONE=Asia/Yekaterinburg
RELEASES_FALLBACK_TO_HTML=0
RELEASES_LIMIT=10
RELEASES_EXTRA_SEARCH_QUERIES=

# Required when RELEASES_SOURCE=yandex_music
YANDEX_MUSIC_TOKEN=
